-- Helper Functions
local function getHunger()
    local gui = LocalPlayer.PlayerGui:FindFirstChild("MainGui")
    if not gui then return 100 end
    local bars = gui:FindFirstChild("Panels") and gui.Panels:FindFirstChild("Stats") and gui.Panels.Stats:FindFirstChild("Bars")
    local hunger = bars and bars:FindFirstChild("Hunger")
    local label = hunger and hunger:FindFirstChild("ValueLabel")
    return label and tonumber(label.Text) or 100
end

local function getFruitSlot(fruit)
    local gui = LocalPlayer.PlayerGui:FindFirstChild("MainGui")
    if not gui then return nil end
    local list = gui:FindFirstChild("RightPanel") and gui.RightPanel:FindFirstChild("Inventory") and gui.RightPanel.Inventory:FindFirstChild("List")
    local slot = list and list:FindFirstChild(fruit)
    return slot and slot.LayoutOrder
end

local function getFruitCount(fruit)
    local gui = LocalPlayer.PlayerGui:FindFirstChild("MainGui")
    if not gui then return 0 end
    local list = gui:FindFirstChild("RightPanel") and gui.RightPanel:FindFirstChild("Inventory") and gui.RightPanel.Inventory:FindFirstChild("List")
    local slot = list and list:FindFirstChild(fruit)
    if slot then
        local qt = slot:FindFirstChild("QuantityImage") and slot.QuantityImage:FindFirstChild("QuantityText")
        return qt and tonumber(qt.Text:gsub(",", "")) or 0
    end
    return 0
end

-- Farming Functions
local function pickup(id)
    if Packets.Pickup and Packets.Pickup.send then
        Packets.Pickup.send(id)
    end
end

local function plant(entityID)
    local id = fruitIds[config.SelectedFruit] or 94
    if Packets.InteractStructure and Packets.InteractStructure.send then
        Packets.InteractStructure.send({entityID = entityID, itemID = id})
    end
end

-- Plant Boxes
local plantBoxes = {}
local function refreshBoxes()
    table.clear(plantBoxes)
    local folder = Workspace:FindFirstChild("Plant Boxes") or Workspace
    for _, v in ipairs(folder:GetDescendants()) do
        if v.Name == "Plant Box" then
            local eid = v:GetAttribute("EntityID")
            if eid then
                table.insert(plantBoxes, {
                    entityID = eid,
                    model = v,
                    part = v.PrimaryPart or v:FindFirstChildWhichIsA("BasePart")
                })
            end
        end
    end
end
