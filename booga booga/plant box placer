local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local LocalPlayer = Players.LocalPlayer
local Packets = require(ReplicatedStorage.Modules.Packets)

local GRID_SIZE = 5.01
local PLACE_RADIUS = 35
local VISUAL_RADIUS = 50
local PLACE_COOLDOWN = 0.08
local RAYCAST_HEIGHT = 220
local SHOW_VISUALIZER = true
local AUTO_PLANT_ENABLED = false

local lastPlaceTime = 0
local gridCenterX = 0
local gridCenterZ = 0
local placedPositions = {}
local visualizationParts = {}
local lastVisualUpdate = 0
lastPosition = Vector3.new(0,0,0)

-- GUI
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "AutoPlantGridGui"
screenGui.ResetOnSpawn = false
screenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")

local mainFrame = Instance.new("Frame")
mainFrame.Name = "MainFrame"
mainFrame.Size = UDim2.new(0, 220, 0, 260)
mainFrame.Position = UDim2.new(0, 10, 0.5, -130)
mainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
mainFrame.BorderSizePixel = 0
mainFrame.Active = true
mainFrame.Draggable = true
mainFrame.Parent = screenGui

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 25)
title.Position = UDim2.new(0, 0, 0, 0)
title.BackgroundTransparency = 1
title.Text = "Auto Place PlantBox"
title.TextColor3 = Color3.fromRGB(200, 200, 200)
title.Font = Enum.Font.GothamBold
title.TextSize = 14
title.Parent = mainFrame

local toggleBtn = Instance.new("TextButton")
toggleBtn.Size = UDim2.new(1, -20, 0, 35)
toggleBtn.Position = UDim2.new(0, 10, 0, 35)
toggleBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
toggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
toggleBtn.Font = Enum.Font.GothamBold
toggleBtn.TextSize = 14
toggleBtn.Text = "Auto Place: OFF"
toggleBtn.Parent = mainFrame

toggleBtn.MouseButton1Click:Connect(function()
    AUTO_PLANT_ENABLED = not AUTO_PLANT_ENABLED
    toggleBtn.Text = AUTO_PLANT_ENABLED and "Auto Place: ON" or "Auto Place: OFF"
    toggleBtn.BackgroundColor3 = AUTO_PLANT_ENABLED and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(50, 50, 50)
end)

local visToggleBtn = Instance.new("TextButton")
visToggleBtn.Size = UDim2.new(1, -20, 0, 35)
visToggleBtn.Position = UDim2.new(0, 10, 0, 80)
visToggleBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
visToggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
visToggleBtn.Font = Enum.Font.GothamBold
visToggleBtn.TextSize = 14
visToggleBtn.Text = "Visualizer: ON"
visToggleBtn.Parent = mainFrame

visToggleBtn.MouseButton1Click:Connect(function()
    SHOW_VISUALIZER = not SHOW_VISUALIZER
    visToggleBtn.Text = SHOW_VISUALIZER and "Visualizer: ON" or "Visualizer: OFF"
end)

local visLabel = Instance.new("TextLabel")
visLabel.Size = UDim2.new(1, -20, 0, 20)
visLabel.Position = UDim2.new(0, 10, 0, 125)
visLabel.BackgroundTransparency = 1
visLabel.Text = "Visual Radius: 50"
visLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
visLabel.Font = Enum.Font.Gotham
visLabel.TextSize = 13
visLabel.Parent = mainFrame

local visBox = Instance.new("TextBox")
visBox.Size = UDim2.new(1, -20, 0, 30)
visBox.Position = UDim2.new(0, 10, 0, 145)
visBox.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
visBox.TextColor3 = Color3.fromRGB(255, 255, 255)
visBox.Text = tostring(VISUAL_RADIUS)
visBox.Font = Enum.Font.Gotham
visBox.TextSize = 14
visBox.Parent = mainFrame

visBox.FocusLost:Connect(function()
    local num = tonumber(visBox.Text)
    if num and num >= 20 and num <= 300 then
        VISUAL_RADIUS = num
        visLabel.Text = "Visual Radius: " .. VISUAL_RADIUS
        createVisualParts()
    else
        visBox.Text = tostring(VISUAL_RADIUS)
    end
end)

local visFolder = Instance.new("Folder")
visFolder.Name = "GridVisualization"
visFolder.Parent = Workspace.CurrentCamera

local raycastParams = RaycastParams.new()
raycastParams.FilterType = Enum.RaycastFilterType.Exclude
raycastParams.IgnoreWater = false

local function getGroundHeight(x, z)
    local result = Workspace:Raycast(Vector3.new(x, RAYCAST_HEIGHT, z), Vector3.new(0, -600, 0), raycastParams)
    return result and result.Position.Y
end

local function createVisualParts()
    for _, p in ipairs(visualizationParts) do p:Destroy() end
    visualizationParts = {}
    local count = math.ceil(VISUAL_RADIUS * 2 / GRID_SIZE) + 1
    for i = 1, math.min(count * count, 100) do
        local part = Instance.new("Part")
        part.Size = Vector3.new(GRID_SIZE - 0.4, 0.2, GRID_SIZE - 0.4)
        part.Anchored = true
        part.CanCollide = false
        part.CanQuery = false
        part.CanTouch = false
        part.Material = Enum.Material.Neon
        part.Transparency = 0.5
        part.Parent = visFolder
        table.insert(visualizationParts, part)
    end
end
createVisualParts()

local function updateGridCenter()
    local char = LocalPlayer.Character
    if not char then return false end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return false end
    gridCenterX = math.round(root.Position.X / GRID_SIZE) * GRID_SIZE
    gridCenterZ = math.round(root.Position.Z / GRID_SIZE) * GRID_SIZE
    return true
end

local function updateVisuals()
    if not SHOW_VISUALIZER then return end
    local now = tick()
    if now - lastVisualUpdate < 0.1 then return end
    lastVisualUpdate = now

    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local idx = 1
    local half = math.ceil(VISUAL_RADIUS / GRID_SIZE)

    for x = -half, half do
        for z = -half, half do
            if idx > #visualizationParts then break end
            local wx = gridCenterX + x * GRID_SIZE
            local wz = gridCenterZ + z * GRID_SIZE
            local part = visualizationParts[idx]

            local inRange = (wx - root.Position.X)^2 + (wz - root.Position.Z)^2 <= PLACE_RADIUS^2

            local y = getGroundHeight(wx, wz)
            if y then
                part.Position = Vector3.new(wx, y + 0.6, wz)
                part.Color = inRange and Color3.fromRGB(0, 255, 100) or Color3.fromRGB(90, 90, 90)
                part.Transparency = inRange and 0.35 or 0.8
                part.Parent = visFolder
            else
                part.Parent = nil
            end
            idx += 1
        end
    end
end

RunService.Heartbeat:Connect(function()
    if not updateGridCenter() then return end
    updateVisuals()

    if not AUTO_PLANT_ENABLED then return end
    if tick() - lastPlaceTime < PLACE_COOLDOWN then return end

    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    if (root.Position - lastPosition).Magnitude > 15 then
        placedPositions = {}
        lastPosition = root.Position
    end

    for _, part in ipairs(visualizationParts) do
        if part.Parent and part.Color == Color3.fromRGB(0, 255, 100) then
            local pos = part.Position
            local key = math.round(pos.X / GRID_SIZE) .. "," .. math.round(pos.Z / GRID_SIZE)
            if not placedPositions[key] or tick() - placedPositions[key] > 3 then
                Packets.PlaceStructure.send({
                    buildingName = "Plant Box",
                    cframe = CFrame.new(pos.X, pos.Y - 0.5, pos.Z)
                })
                placedPositions[key] = tick()
                lastPlaceTime = tick()
                return
            end
        end
    end
end)
