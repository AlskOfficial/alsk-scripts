-- Toggle minimize
local function toggleMinimize()
    isMinimized = not isMinimized
    if isMinimized then
        for _, elem in ipairs({title, infoFrame, itemLabel, itemBox, amountLabel, amountBox, buyButton}) do
            elem.Visible = false
        end
        autoCompleteFrame.Visible = false
        mainFrame.Size = UDim2.new(0, 30, 0, 30)
        closeButton.Position = UDim2.new(0, 0, 0, 0)
        closeButton.Text = "+"
        closeButton.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
    else
        for _, elem in ipairs({title, infoFrame, itemLabel, itemBox, amountLabel, amountBox, buyButton}) do
            elem.Visible = true
        end
        mainFrame.Size = originalSize
        closeButton.Position = originalClosePos
        closeButton.Text = "X"
        closeButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    end
end

-- Make draggable
local function makeDraggable(titleBar, frame)
    local dragging = false
    local dragStart = nil
    local startPos = nil
    
    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            if dragging then
                local delta = input.Position - dragStart
                frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            end
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

