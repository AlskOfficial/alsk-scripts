-- Get current inventory amount
local function getInventoryAmount(itemName)
    local mainGui = LocalPlayer.PlayerGui:FindFirstChild("MainGui")
    if not mainGui then return 0 end
    
    local rightPanel = mainGui:FindFirstChild("RightPanel")
    local inventory = rightPanel and rightPanel:FindFirstChild("Inventory")
    local list = inventory and inventory:FindFirstChild("List")
    
    if list then
        local itemFrame = list:FindFirstChild(itemName)
        if itemFrame then
            local qtyImage = itemFrame:FindFirstChild("QuantityImage")
            if qtyImage then
                local qtyText = qtyImage:FindFirstChild("QuantityText")
                return tonumber(qtyText.Text) or 0
            end
        end
    end
    return 0
end

-- Find item by name or ID
local function findItem(query)
    local q = tostring(query):lower():match("^%s*(.-)%s*$")
    for name, data in pairs(itemsData) do
        if name:lower() == q then
            return {id = data[1], price = data[2], received = data[3], name = name}
        end
    end
    
    local id = tonumber(q)
    if id and idToData[id] then
        local d = idToData[id]
        return {id = d.id, price = d.price, received = d.received, name = d.name}
    end
    return nil
end

-- Update price preview
local function updatePreview()
    local itemText = itemBox.Text
    local amount = tonumber(amountBox.Text)
    
    if not itemText or itemText == "" or not amount or amount < 1 then
        priceLabel.Text = "Total Price: 0 coins"
        receivedLabel.Text = "You will receive: 0 items"
        return
    end
    
    local item = findItem(itemText)
    if not item then
        priceLabel.Text = "Total Price: Item not found!"
        priceLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        receivedLabel.Text = "You will receive: 0 items"
        return
    end
    
    priceLabel.TextColor3 = Color3.fromRGB(255, 215, 0)
    priceLabel.Text = string.format("Total Price: %d coins", item.price * amount)
    receivedLabel.Text = string.format("You will receive: %d %s", item.received * amount, item.name)
end

-- Auto-complete
local function updateAutoComplete()
    local text = itemBox.Text:lower()
    local matches = {}
    
    for name in pairs(itemsData) do
        if name:lower():sub(1, #text) == text then
            table.insert(matches, name)
        end
    end
    
    table.sort(matches)
    suggestions = matches
    selectedIndex = 1
    
    -- Clear old buttons
    for _, child in ipairs(scrolling:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end
    
    if #matches == 0 then
        autoCompleteFrame.Visible = false
        return
    end
    
    autoCompleteFrame.Visible = true
    autoCompleteFrame.Size = UDim2.new(1, -120, 0, math.min(120, #matches * 30 + 10))
    
    for i, name in ipairs(matches) do
        local btn = Instance.new("TextButton")
        btn.Name = name
        btn.Size = UDim2.new(1, 0, 0, 28)
        btn.BackgroundColor3 = (i == selectedIndex) and Color3.fromRGB(70, 70, 90) or Color3.fromRGB(50, 50, 50)
        btn.Text = name
        btn.TextColor3 = Color3.new(1, 1, 1)
        btn.TextSize = 14
        btn.Font = Enum.Font.Gotham
        btn.AutoButtonColor = false
        btn.Parent = scrolling
        
        btn.MouseButton1Click:Connect(function()
            itemBox.Text = name
            autoCompleteFrame.Visible = false
        end)
    end
    
    scrolling.CanvasSize = UDim2.new(0, 0, 0, #matches * 30)
end

-- Highlight selection
local function updateSelectionHighlight()
    for _, btn in ipairs(scrolling:GetChildren()) do
        if btn:IsA("TextButton") then
            btn.BackgroundColor3 = (btn.Text == suggestions[selectedIndex]) and Color3.fromRGB(70, 70, 90) or Color3.fromRGB(50, 50, 50)
        end
    end
end

-- Buy logic
local function performBuy()
    local itemText = itemBox.Text
    local amount = tonumber(amountBox.Text)
    
    if not itemText or itemText == "" or not amount or amount < 1 then return end
    
    local item = findItem(itemText)
    if not item then return end
    
    buyButton.Interactable = false
    buyButton.Text = "Buying..."
    buyButton.BackgroundColor3 = Color3.fromRGB(150, 150, 0)
    
    local initialAmount = getInventoryAmount(item.name)
    
    -- Main purchase loop
    for i = 1, amount do
        pcall(function()
            Packets.PurchaseFromShop.send(item.id, 1)
        end)
        task.wait(0.02)
    end
    
    task.wait(0.5)
    
    -- Recovery if needed
    local finalAmount = getInventoryAmount(item.name)
    local missing = (finalAmount or 0) - initialAmount - (amount * item.received)
    
    if missing < 0 then
        local toRecover = math.ceil(math.abs(missing) / item.received)
        buyButton.Text = "Recovering (" .. toRecover .. ")..."
        buyButton.BackgroundColor3 = Color3.fromRGB(200, 100, 0)
        
        for i = 1, toRecover do
            pcall(function()
                Packets.PurchaseFromShop.send(item.id, 1)
            end)
            task.wait(0.045)
        end
    end
    
    buyButton.Text = "Quick Buy"
    buyButton.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
    buyButton.Interactable = true
end

-- Connections
itemBox:GetPropertyChangedSignal("Text"):Connect(updateAutoComplete)
amountBox:GetPropertyChangedSignal("Text"):Connect(updatePreview)

itemBox.Focused:Connect(updateAutoComplete)
itemBox.FocusLost:Connect(function()
    task.wait(0.1)
    autoCompleteFrame.Visible = false
end)

UserInputService.InputBegan:Connect(function(input, processed)
    if processed or not autoCompleteFrame.Visible then return end
    
    if input.KeyCode == Enum.KeyCode.Up then
        selectedIndex = selectedIndex - 1
        if selectedIndex < 1 then selectedIndex = #suggestions end
        updateSelectionHighlight()
    elseif input.KeyCode == Enum.KeyCode.Down then
        selectedIndex = selectedIndex + 1
        if selectedIndex > #suggestions then selectedIndex = 1 end
        updateSelectionHighlight()
    elseif input.KeyCode == Enum.KeyCode.Return or input.KeyCode == Enum.KeyCode.Tab then
        if suggestions[selectedIndex] then
            itemBox.Text = suggestions[selectedIndex]
        end
        autoCompleteFrame.Visible = false
    elseif input.KeyCode == Enum.KeyCode.Escape then
        autoCompleteFrame.Visible = false
    end
end)

buyButton.MouseButton1Click:Connect(performBuy)

-- Initialize
mainFrame.Visible = true
updatePreview()
