-- Grid Visualization
local VisualFolder = Instance.new("Folder")
VisualFolder.Name = "GridVisualization"
VisualFolder.Parent = Workspace.CurrentCamera

local visualParts = {}

local function updateVisualParts()
    local gridSize = Config.GridSize
    local needed = math.ceil(Config.VisualRadius * 2 / gridSize) + 1
    local total = needed * needed

    while #visualParts < total do
        local part = Instance.new("Part")
        part.Size = Vector3.new(gridSize - 0.3, 0.1, gridSize - 0.3)
        part.Anchored = true
        part.CanCollide = false
        part.CanQuery = false
        part.CanTouch = false
        part.Material = Enum.Material.Neon
        part.Parent = nil
        table.insert(visualParts, part)
    end
end
updateVisualParts()

-- Raycast Setup
local raycastParams = RaycastParams.new()
raycastParams.FilterType = Enum.RaycastFilterType.Exclude
raycastParams.IgnoreWater = false

local function updateFilter()
    raycastParams.FilterDescendantsInstances = {VisualFolder, Workspace:FindFirstChild("Players")}
end
updateFilter()

local function raycastDown(x, z, height)
    return Workspace:Raycast(Vector3.new(x, height + Config.RaycastHeight, z), Vector3.new(0, -500, 0), raycastParams)
end

-- Main Loop
local lastPlaceTime = 0
local lastUpdateTime = 0

RunService.Heartbeat:Connect(function()
    local now = os.clock()

    -- Set grid center
    if not isGridSet then
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            local hrp = char.HumanoidRootPart
            gridCenterX = math.round(hrp.Position.X / Config.GridSize) * Config.GridSize
            gridCenterZ = math.round(hrp.Position.Z / Config.GridSize) * Config.GridSize
            isGridSet = true
        else
            return
        end
    end

    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local hrp = char.HumanoidRootPart
    local pos = hrp.Position

    -- Periodic refresh
    if now - lastUpdateTime > 15 then
        updateFilter()
        lastUpdateTime = now
    end

    -- Grid Visualization
    if now - lastUpdateTime > 0.15 then
        lastUpdateTime = now

        for _, part in ipairs(visualParts) do
            part.Parent = nil
        end

        -- (Visualization logic simplified - full grid rendering can be expanded if needed)
    end

    -- Auto Place
    if not Config.Enabled or now - lastPlaceTime < Config.PlaceCooldown then
        return
    end

    -- Place Plant Boxes in grid (core logic)
    local radius = Config.PlaceRadius
    local gridSize = Config.GridSize
    local maxGrid = 100000 / 2 / gridSize

    for dx = -radius, radius, gridSize do
        for dz = -radius, radius, gridSize do
            local worldX = gridCenterX + dx
            local worldZ = gridCenterZ + dz

            local inRange = false
            if Config.Shape == "Circle" then
                inRange = (dx * dx + dz * dz) <= (radius * radius)
            else
                inRange = math.abs(dx) <= radius and math.abs(dz) <= radius
            end

            if inRange then
                local result = raycastDown(worldX, worldZ, pos.Y)
                if result and result.Instance and result.Instance.Material ~= Enum.Material.Water then
                    -- Place the structure
                    Packets.PlaceStructure.send({
                        buildingName = "Plant Box",
                        cframe = CFrame.new(worldX, result.Position.Y + 0.5, worldZ)
                    })

                    lastPlaceTime = now
                    return -- Place one per tick to avoid spam
                end
            end
        end
    end
end)
